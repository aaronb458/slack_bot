# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Anthropic API Key for Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key

# Claude model to use (default: claude-sonnet-4-5-20250929)
# Options: claude-sonnet-4-5-20250929 (best value), claude-opus-4-5-20251101 (smartest)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Comma-separated Slack user IDs authorized to DM the bot and receive reports.
# Find your ID: click your profile in Slack → ... → Copy member ID
# Example: U01ABCDEF,U02GHIJKL
AUTHORIZED_USERS=

# Comma-separated Slack user IDs that are YOUR team members (not clients).
# Used by the intelligence module to determine who is "team" vs "client".
# If not set, falls back to AUTHORIZED_USERS.
# Example: U01ABCDEF,U02GHIJKL,U03MNOPQR
TEAM_USER_IDS=

# Comma-separated channel names to exclude from intelligence scans.
# Default: general,random
# Example: general,random,social,watercooler
EXCLUDE_CHANNELS=

# Enable or disable draft message generation in scans and AI tools.
# Set to false to get priority queue / analysis without suggested messages.
# Default: true
DRAFTS_ENABLED=true

# Draft message tone/style preset.
# Options: casual, professional, friendly
#   casual       — "Hey {Name}", "Happy [Day]!", warm and personal (default)
#   professional — "Hi {Name}", "Best regards.", polished and buttoned-up
#   friendly     — "Hi {Name}!", "Have a great day!", warm but less personal
# Default: casual
DRAFT_STYLE=casual
