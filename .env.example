# ============================================================
# REQUIRED — Slack Tokens
# ============================================================
# You get these from https://api.slack.com/apps (see README for walkthrough)

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# ============================================================
# REQUIRED — AI Provider
# ============================================================
# Choose ONE provider. The bot needs AI to answer your questions.
#
# Option A: OpenRouter (RECOMMENDED — works with many AI models)
#   1. Go to https://openrouter.ai/keys
#   2. Create an account and add credits ($5 minimum)
#   3. Create an API key
#   4. Set AI_PROVIDER=openrouter and paste your key below
#
# Option B: Anthropic (direct — Claude models only)
#   1. Go to https://console.anthropic.com/
#   2. Create an account and add credits ($5 minimum)
#   3. Go to API Keys → Create Key
#   4. Set AI_PROVIDER=anthropic and paste your key below

AI_PROVIDER=openrouter

# Paste your API key for whichever provider you chose above.
# Only fill in ONE of these — the one that matches your AI_PROVIDER.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Which AI model to use. Leave blank for the default (recommended).
# Default for OpenRouter: anthropic/claude-sonnet-4-5
# Default for Anthropic:  claude-sonnet-4-5-20250929
# Browse OpenRouter models: https://openrouter.ai/models
# Examples: google/gemini-2.5-pro, openai/gpt-4o, meta-llama/llama-4-maverick
AI_MODEL=

# ============================================================
# REQUIRED — Who Can Use the Bot
# ============================================================
# Your Slack user ID (the bot only responds to people listed here).
# To find your ID: open Slack → click your profile picture → Profile → ⋮ → Copy member ID
# For multiple people, separate with commas: U01ABCDEF,U02GHIJKL
AUTHORIZED_USERS=

# ============================================================
# RECOMMENDED — Your Identity
# ============================================================
# Tell the bot who you are so it can personalize responses.

# Your first name — the AI will say "I'm [name]'s assistant"
# Example: Sarah
BOT_OWNER_NAME=

# What you do — helps the AI understand your perspective
# Default: a project manager / business owner
# Examples:
#   a marketing agency owner
#   the head of client services
#   a freelance web developer
OWNER_ROLE=

# ============================================================
# OPTIONAL — Team Members
# ============================================================
# Slack user IDs of your team (not clients). This tells the bot who is
# "your team" vs "a client" when analyzing channels.
# If not set, falls back to AUTHORIZED_USERS.
# Example: U01ABCDEF,U02GHIJKL,U03MNOPQR
TEAM_USER_IDS=

# Channels to skip during scans (comma-separated names).
# Default: general,random
EXCLUDE_CHANNELS=

# ============================================================
# OPTIONAL — Draft Messages
# ============================================================
# The bot can suggest draft messages for channels that need a response.

# Turn drafts on or off. Set to false to disable.
# Default: true
DRAFTS_ENABLED=true

# Optional: Use a cheaper/faster model specifically for draft generation.
# If not set, uses your main AI_MODEL.
# Example: anthropic/claude-haiku-3-5 (fast and cheap for drafts)
DRAFT_MODEL=

# Draft message tone. Options: casual, professional, friendly
#   casual       — "Hey Sarah," ... "Happy Monday!"  (warm, personal)
#   professional — "Hi Sarah,"  ... "Best regards."   (polished, formal)
#   friendly     — "Hi Sarah!"  ... "Have a great day!" (warm, less personal)
# Default: casual
DRAFT_STYLE=casual

# ============================================================
# OPTIONAL — AI Personality
# ============================================================
# Extra instructions for how the AI talks to you.
# Leave blank for default (concise, direct, professional).
# Examples:
#   Be casual and use humor. Keep responses short.
#   Always suggest next steps. Be proactive about deadlines.
#   Speak to me like a teammate, not a robot.
BOT_PERSONALITY=
